.page {
  width: 100%;
  height: 100vh;
  background: #0a0a12;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* === 深空背景 === */
.deep-space {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    180deg,
    rgba(10, 5, 25, 0.95) 0%,
    rgba(15, 8, 35, 0.9) 40%,
    rgba(20, 15, 40, 0.85) 100%
  );
  z-index: 0;
}

/* === 粒子背景 === */
.background-particles {
  position: absolute;
  width: 100%;
  height: 100%;
  z-index: 1;
  overflow: hidden;
}

.particle {
  position: absolute;
  width: 2rpx;
  height: 2rpx;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 0 4rpx rgba(255, 255, 255, 0.8);
  animation: float-up 8s linear infinite;
}

.particle:nth-child(odd) {
  background: rgba(100, 200, 255, 0.6);
  box-shadow: 0 0 4rpx rgba(100, 200, 255, 0.5);
  animation-duration: 10s;
}

.particle:nth-child(3n) {
  background: rgba(201, 169, 110, 0.5);
  box-shadow: 0 0 4rpx rgba(201, 169, 110, 0.4);
  animation-duration: 12s;
}

@keyframes float-up {
  0% {
    transform: translateY(100vh) translateX(0);
    opacity: 0;
  }
  5% {
    opacity: 1;
  }
  95% {
    opacity: 0.8;
  }
  100% {
    transform: translateY(-100vh) translateX(60rpx);
    opacity: 0;
  }
}

/* === 中心内容 === */
.center-content {
  position: relative;
  z-index: 10;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 60rpx;
  align-items: center;
}

.title-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  animation: title-fade-in 1s ease-out;
}

@keyframes title-fade-in {
  from {
    opacity: 0;
    transform: translateY(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.main-title {
  font-size: 120rpx;
  font-weight: 700;
  color: #f0e6d2;
  letter-spacing: 20rpx;
  text-shadow: 0 0 60rpx rgba(100, 180, 255, 0.4);
  margin: 0;
  line-height: 1;
}

.sub-title {
  font-size: 36rpx;
  color: #c9a96e;
  letter-spacing: 8rpx;
  font-weight: 600;
  opacity: 0.9;
}

.description {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  animation: desc-fade-in 1.2s ease-out 0.3s both;
}

@keyframes desc-fade-in {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.description text {
  font-size: 28rpx;
  color: #9aaa9f;
  letter-spacing: 4rpx;
  font-weight: 500;
}

/* === 按钮 === */
.btn-start {
  padding: 20rpx 80rpx;
  height: auto;
  line-height: 1;
  background: linear-gradient(135deg, rgba(100, 180, 255, 0.9) 0%, rgba(70, 150, 220, 0.8) 100%);
  color: #0a0a12;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 50rpx;
  border: 2rpx solid rgba(150, 220, 255, 0.6);
  box-shadow: 0 0 40rpx rgba(100, 180, 255, 0.4);
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  animation: btn-appear 1.5s ease-out 0.6s both;
}

@keyframes btn-appear {
  from {
    opacity: 0;
    transform: scale(0.8);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.btn-start::after {
  border: none;
}

.btn-start:active {
  transform: scale(0.95);
  box-shadow: 0 0 60rpx rgba(100, 180, 255, 0.6);
}

/* === 页脚 === */
.footer-text {
  position: absolute;
  bottom: 40rpx;
  left: 0;
  right: 0;
  text-align: center;
  z-index: 5;
}

.footer-text text {
  font-size: 24rpx;
  color: #5a6a5f;
  letter-spacing: 6rpx;
  opacity: 0.7;
}

