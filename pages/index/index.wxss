.page {
  min-height: 100vh;
  padding: 48rpx 40rpx 80rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #0a0a0f 0%, #111118 45%, #0a0a0f 100%);
  position: relative;
  overflow: hidden;
}

.glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.35;
  pointer-events: none;
}

.glow-1 {
  width: 400rpx;
  height: 400rpx;
  background: rgba(201, 169, 110, 0.25);
  top: -80rpx;
  right: -100rpx;
}

.glow-2 {
  width: 320rpx;
  height: 320rpx;
  background: rgba(184, 55, 45, 0.12);
  bottom: 200rpx;
  left: -120rpx;
}

.hero {
  position: relative;
  z-index: 1;
  margin-top: 72rpx;
  text-align: center;
}

.kicker {
  display: block;
  font-size: 24rpx;
  letter-spacing: 12rpx;
  color: #c9a96e;
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 72rpx;
  font-weight: 600;
  letter-spacing: 16rpx;
  color: #f0ede6;
  margin-bottom: 28rpx;
}

.name {
  display: block;
  font-size: 28rpx;
  color: #9a9aaa;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.years {
  display: block;
  font-size: 24rpx;
  color: #5a5a6a;
  letter-spacing: 8rpx;
}

.quote {
  position: relative;
  z-index: 1;
  margin: 56rpx 0 40rpx;
  padding: 32rpx 28rpx;
  border-left: 4rpx solid rgba(201, 169, 110, 0.6);
  background: rgba(26, 26, 36, 0.6);
  border-radius: 0 16rpx 16rpx 0;
}

.quote-line {
  font-size: 28rpx;
  color: #e8d5a8;
  line-height: 1.75;
}

.desc {
  position: relative;
  z-index: 1;
  margin-bottom: 48rpx;
}

.desc-text {
  font-size: 26rpx;
  color: #9a9aaa;
  line-height: 1.85;
}

.btn-primary {
  position: relative;
  z-index: 1;
  width: 100% !important;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #c9a96e 0%, #8b6914 100%);
  color: #0a0a0f;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 8rpx;
  border-radius: 48rpx;
  border: none;
  margin-bottom: 40rpx;
}

.btn-primary::after {
  border: none;
}

.tip {
  position: relative;
  z-index: 1;
  padding: 28rpx;
  background: rgba(201, 169, 110, 0.08);
  border-radius: 16rpx;
  border: 1rpx solid rgba(201, 169, 110, 0.2);
  margin-bottom: 48rpx;
}

.tip-title {
  display: block;
  font-size: 24rpx;
  color: #c9a96e;
  margin-bottom: 12rpx;
}

.tip-text {
  font-size: 22rpx;
  color: #7a7a8a;
  line-height: 1.65;
}

.footer {
  position: relative;
  z-index: 1;
  text-align: center;
}

.footer text {
  font-size: 22rpx;
  color: #5a5a6a;
  line-height: 1.6;
}
