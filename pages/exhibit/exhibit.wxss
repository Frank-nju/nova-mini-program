  letter-spacing: 12rpx;
  animation: title-pulse 2s ease-in-out infinite;
}

@keyframes title-pulse {
  0%, 100% {
    text-shadow: 0 0 40rpx rgba(100, 200, 255, 0.3), 0 0 80rpx rgba(201, 169, 110, 0.2);
    transform: scale(1);
  }
  50% {
    text-shadow: 0 0 60rpx rgba(100, 200, 255, 0.5), 0 0 100rpx rgba(201, 169, 110, 0.3);
