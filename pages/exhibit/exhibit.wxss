@keyframes wu-observe {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-10rpx) rotate(-1deg); }
}

.experiment-aura {
  position: absolute;
  width: 200rpx;
  height: 280rpx;
  background: radial-gradient(ellipse at 50% 40%, rgba(100, 200, 255, 0.08), transparent 60%);
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  filter: blur(30rpx);
  animation: exp-aura-pulse 3.5s ease-in-out infinite;
}

@keyframes exp-aura-pulse {
  0%, 100% { opacity: 0.2; }
  50% { opacity: 0.4; }
}

/* 尾声-荣耀归来 */
.sunset-room-bg {
  position: absolute;
  width: 100%;
  height: 100%;
}

.window-frame {
  position: absolute;
  right: 10%;
  top: 10%;
  width: 200rpx;
  height: 300rpx;
  border: 3rpx solid rgba(180, 140, 80, 0.4);
  border-radius: 8rpx;
  background: linear-gradient(135deg, rgba(255, 180, 80, 0.15), rgba(255, 120, 60, 0.1));
  overflow: hidden;
}

.window-light {
  position: absolute;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(255, 200, 100, 0.3), transparent);
  animation: window-glow 4s ease-in-out infinite;
}

@keyframes window-glow {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 0.7; }
}

.sunset-glow {
  position: absolute;
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(255, 180, 80, 0.3), transparent 70%);
  right: -200rpx;
  top: -150rpx;
  border-radius: 50%;
  filter: blur(50rpx);
  animation: sunset-breath 5s ease-in-out infinite;
}

@keyframes sunset-breath {
  0%, 100% { transform: scale(1); opacity: 0.3; }
  50% { transform: scale(1.1); opacity: 0.5; }
}

.room-silhouette {
  position: absolute;
  left: 10%;
  bottom: 10%;
  width: 250rpx;
  height: 200rpx;
  background: linear-gradient(to right, rgba(60, 40, 20, 0.3), transparent);
  border-radius: 8rpx;
  opacity: 0.3;
}

.room-furniture {
  position: absolute;
  width: 100%;
  height: 100%;
  background: repeating-linear-gradient(
    90deg,
    rgba(100, 80, 50, 0.2),
    rgba(100, 80, 50, 0.2) 20rpx,
    transparent 20rpx,
    transparent 40rpx
  );
}

.character-elderly-wu {
  position: absolute;
  left: 15%;
  top: 15%;
  width: 170rpx;
  height: 300rpx;
  z-index: 3;
}

.elderly-wu-silhouette {
  width: 100%;
  height: 100%;
  background: linear-gradient(to right, rgba(100, 80, 60, 0.2), transparent);
  border-radius: 50% 50% 40% 40%;
  filter: blur(2rpx);
}

.elderly-aura {
  position: absolute;
  width: 240rpx;
  height: 340rpx;
  background: radial-gradient(ellipse at 50% 50%, rgba(255, 180, 80, 0.08), transparent 60%);
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  filter: blur(35rpx);
  animation: elderly-glow 4s ease-in-out infinite;
}

@keyframes elderly-glow {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 0.5; }
}

.light-beam-effect {
  position: absolute;
  width: 100rpx;
  height: 400rpx;
  background: linear-gradient(to bottom, rgba(255, 200, 100, 0.3), transparent);
  left: 50%;
  top: -50%;
  transform: translateX(-50%);
  border-radius: 50%;
  filter: blur(20rpx);
  animation: beam-shine 3s ease-in-out infinite;
}

@keyframes beam-shine {
  0%, 100% { opacity: 0.2; }
  50% { opacity: 0.5; }
}

