.scene-universe {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 200rpx;
}

.nebula {
  width: 250rpx;
  height: 250rpx;
  border-radius: 50%;
  filter: blur(40rpx);
  opacity: 0.4;
}

.nebula-1 {
  background: rgba(100, 200, 255, 0.3);
  animation: nebula-breath 4s ease-in-out infinite;
}

.nebula-2 {
  background: rgba(255, 105, 180, 0.2);
  animation: nebula-breath 5s ease-in-out infinite 0.5s;
}

@keyframes nebula-breath {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.light-beam {
  position: absolute;
  width: 4rpx;
  height: 600rpx;
  background: linear-gradient(to bottom, rgba(100, 200, 255, 0.3), transparent);
  left: 50%;
  top: 10%;
  transform: translateX(-50%);
  animation: beam-pulse 3s ease-in-out infinite;
}

@keyframes beam-pulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 0.7; }
}

/* 粒子效果 */
.particles-section {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  z-index: 0;
}

@keyframes float-up {
  0% {
    transform: translateY(0) translateX(0);
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  90% {
    opacity: 1;
  }
  100% {
    transform: translateY(-100vh) translateX(50px);
    opacity: 0;
  }
}

@keyframes float-up-reverse {
  0% {
    transform: translateY(0) translateX(0);
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  90% {
    opacity: 1;
  }
  100% {
    transform: translateY(-100vh) translateX(-50px);
    opacity: 0;
  }
}

.particle-dot {
  position: absolute;
  width: 4rpx;
  height: 4rpx;
  background: rgba(100, 200, 255, 0.6);
  border-radius: 50%;
  box-shadow: 0 0 8rpx rgba(100, 200, 255, 0.4);
}

.particle-dot:nth-child(odd) {
  animation: float-up 12s linear infinite;
  width: 2rpx;
  height: 2rpx;
  left: calc(15% + 20rpx * var(--i));
  background: rgba(201, 169, 110, 0.5);
}

.particle-dot:nth-child(even) {
  animation: float-up-reverse 14s linear infinite;
  width: 3rpx;
  height: 3rpx;
  right: calc(15% + 30rpx * var(--i));
  background: rgba(255, 105, 180, 0.4);
}

/* === 卷轴样式 === */
.section-content {
  position: absolute;
  z-index: 11;
  text-align: center;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 100rpx;
  pointer-events: none;
}

.scroll-hint {
  margin-top: 48rpx;
  font-size: 24rpx;
  color: #64c8ff;
  opacity: 0.7;
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(20rpx);
  }
}

/* 卷轴容器 */
.scroll-container {
  width: 100%;
  height: 60%;
  display: flex;
  align-items: center;
  justify-content: center;
  perspective: 1200px;
}

/* 通用卷轴 */
.scroll-item {
  position: relative;
  width: 300rpx;
  height: 420rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  overflow: hidden;
  cursor: pointer;
  animation: scroll-float 3s ease-in-out infinite;
}

@keyframes scroll-float {
  0%, 100% {
    transform: translateY(0) rotateZ(0deg);
  }
  50% {
    transform: translateY(-25rpx) rotateZ(1deg);
  }
}

.scroll-item:active {
  transform: scale(0.95) !important;
}

.scroll-glow {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 20rpx;
  box-shadow: 0 0 60rpx rgba(100, 200, 255, 0.3), inset 0 0 60rpx rgba(100, 200, 255, 0.05);
  z-index: 1;
  pointer-events: none;
}

.scroll-frame {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  pointer-events: none;
}

.frame-top, .frame-bottom, .frame-left, .frame-right {
  position: absolute;
  background: linear-gradient(90deg, rgba(100, 200, 255, 0.5), transparent);
  animation: frame-glow 2s ease-in-out infinite;
}

.frame-top {
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(100, 200, 255, 0.6), transparent);
}

.frame-bottom {
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(201, 169, 110, 0.6), transparent);
}

.frame-left {
  top: 0;
  left: 0;
  width: 2rpx;
  bottom: 0;
  background: linear-gradient(180deg, rgba(100, 200, 255, 0.4), transparent);
}

.frame-right {
  top: 0;
  right: 0;
  width: 2rpx;
  bottom: 0;
  background: linear-gradient(180deg, rgba(201, 169, 110, 0.4), transparent);
}

@keyframes frame-glow {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 0.8; }
}

/* 晶体卷轴（序章） */
.scroll-crystal {
  background: linear-gradient(135deg, rgba(64, 120, 180, 0.6) 0%, rgba(30, 60, 120, 0.8) 100%);
  border: 2rpx solid rgba(100, 200, 255, 0.6);
  backdrop-filter: blur(20px);
}

.scroll-crystal .scroll-content {
  background: radial-gradient(circle at 30% 30%, rgba(100, 200, 255, 0.3), transparent);
}

/* 书籍卷轴（生平履历） */
.scroll-book {
  background: linear-gradient(135deg, rgba(80, 60, 40, 0.6) 0%, rgba(40, 30, 20, 0.8) 100%);
  border: 2rpx solid rgba(201, 169, 110, 0.5);
  backdrop-filter: blur(20px);
}

.book-pages {
  position: absolute;
  width: 200rpx;
  height: 280rpx;
  background: repeating-linear-gradient(
    90deg,
    rgba(255, 255, 255, 0.05) 0,
    rgba(255, 255, 255, 0.05) 10rpx,
    transparent 10rpx,
    transparent 20rpx
  );
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  z-index: 0;
  border: 1rpx solid rgba(201, 169, 110, 0.3);
  border-radius: 4rpx;
}

/* 传统卷轴（治学风骨） */
.scroll-scroll {
  background: linear-gradient(135deg, rgba(100, 80, 60, 0.6) 0%, rgba(50, 40, 30, 0.8) 100%);
  border: 3rpx solid rgba(201, 169, 110, 0.6);
  backdrop-filter: blur(20px);
}

.scroll-roll-left, .scroll-roll-right {
  position: absolute;
  width: 40rpx;
  height: 280rpx;
  background: linear-gradient(90deg, rgba(101, 84, 68, 0.8), rgba(101, 84, 68, 0.5));
  border: 1rpx solid rgba(201, 169, 110, 0.4);
  border-radius: 20rpx;
  z-index: 1;
  top: 50%;
  transform: translateY(-50%);
}

.scroll-roll-left {
  left: 20rpx;
}

.scroll-roll-right {
  right: 20rpx;
}

/* 实验室卷轴（科研丰碑） */
.scroll-lab {
  background: linear-gradient(135deg, rgba(60, 100, 120, 0.6) 0%, rgba(30, 60, 80, 0.8) 100%);
  border: 2rpx solid rgba(100, 200, 255, 0.5);
  backdrop-filter: blur(20px);
}

.reactor-core {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  z-index: 0;
  background: radial-gradient(circle at 35% 35%, rgba(255, 100, 100, 0.8), rgba(255, 100, 100, 0.2), transparent);
  border-radius: 50%;
  box-shadow: 0 0 40rpx rgba(255, 100, 100, 0.4), inset 0 0 40rpx rgba(255, 100, 100, 0.2);
  animation: reactor-pulse 2s ease-in-out infinite;
}

@keyframes reactor-pulse {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; }
  50% { transform: translate(-50%, -50%) scale(1.2); opacity: 1; }
}

/* 宇宙卷轴（尾声） */
.scroll-universe {
  background: linear-gradient(135deg, rgba(40, 30, 80, 0.6) 0%, rgba(20, 10, 40, 0.8) 100%);
  border: 2rpx solid rgba(100, 200, 255, 0.5);
  backdrop-filter: blur(20px);
}

.universe-orb {
  position: absolute;
  width: 140rpx;
  height: 140rpx;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  z-index: 0;
  background: radial-gradient(circle at 35% 35%, rgba(100, 200, 255, 0.9), rgba(100, 200, 255, 0.3), transparent);
  border-radius: 50%;
  box-shadow: 0 0 60rpx rgba(100, 200, 255, 0.5), inset 0 0 60rpx rgba(100, 200, 255, 0.3);
  animation: universe-spin 4s linear infinite;
}

@keyframes universe-spin {
  from { transform: translate(-50%, -50%) rotate(0deg); }
  to { transform: translate(-50%, -50%) rotate(360deg); }
}

.scroll-content {
  position: relative;
  z-index: 2;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.scroll-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #f0ede6;
  text-shadow: 0 0 20rpx rgba(100, 200, 255, 0.4);
}

.scroll-desc {
  display: block;
  font-size: 26rpx;
  color: #c9a96e;
  opacity: 0.9;
}

.scroll-shine {
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent,
    rgba(255, 255, 255, 0.15),
    transparent
  );
  animation: shine-sweep 3s infinite;
  pointer-events: none;
}

@keyframes shine-sweep {
  0% {
    transform: translateX(-100%) translateY(-100%);
  }
  100% {
    transform: translateX(100%) translateY(100%);
  }
}

/* === 常驻按钮栏 === */
.floating-buttons {
  position: fixed;
  right: 32rpx;
  bottom: 80rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 200;
}

.float-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 2rpx solid;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #0a0a0f;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  box-shadow: 0 0 30rpx currentColor;
}

.float-btn::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.4), transparent);
  animation: pulse-ring 2s infinite;
}

@keyframes pulse-ring {
  0% {
    transform: scale(0);
    opacity: 1;
  }
  100% {
    transform: scale(1);
    opacity: 0;
  }
}

.float-btn:active {
  transform: scale(0.85);
}

.btn-clouds {
  background: linear-gradient(135deg, #64c8ff 0%, #4a88c8 100%);
  border-color: rgba(100, 200, 255, 0.8);
  color: #0a0a0f;
}

.btn-badge {
  background: linear-gradient(135deg, #ffd700 0%, #daa520 100%);
  border-color: rgba(255, 215, 0, 0.8);
  color: #0a0a0f;
}

.btn-ai {
  background: linear-gradient(135deg, #ff69b4 0%, #ff1493 100%);
  border-color: rgba(255, 105, 180, 0.8);
  color: #fff;
}

.btn-more {
  background: linear-gradient(135deg, #9370db 0%, #6a4c93 100%);
  border-color: rgba(147, 112, 219, 0.8);
  color: #fff;
}

.badge-dot {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 24rpx;
  height: 24rpx;
  background: #ff6347;
  border-radius: 50%;
  border: 2rpx solid #0a0a0f;
  z-index: 3;
  animation: badge-pulse 1s ease-in-out infinite;
}

@keyframes badge-pulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 0 12rpx #ff6347;
  }
  50% {
    transform: scale(1.2);
    box-shadow: 0 0 24rpx #ff6347;
  }
}

/* === 面板样式 === */
.panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 70vh;
  background: rgba(10, 10, 15, 0.98);
  border-top: 2rpx solid rgba(100, 200, 255, 0.5);
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 32rpx 32rpx;
  z-index: 300;
  animation: slide-up-panel 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  backdrop-filter: blur(40px);
  box-shadow: 0 -20rpx 60rpx rgba(100, 200, 255, 0.2);
  overflow-y: auto;
}

@keyframes slide-up-panel {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid rgba(100, 200, 255, 0.3);
}

.panel-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #f0ede6;
  text-shadow: 0 0 20rpx rgba(100, 200, 255, 0.3);
}

.close-btn {
  font-size: 44rpx;
  color: #64c8ff;
  cursor: pointer;
  transition: all 0.3s ease;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-btn:active {
  transform: rotate(90deg) scale(0.7);
}

/* === 云图面板 === */
.clouds-panel {
  bottom: 0;
}

.cloud-map-container {
  width: 100%;
  height: 500rpx;
  position: relative;
}

.cloud-canvas {
  width: 100%;
  height: 100%;
  background: rgba(20, 20, 40, 0.6);
  border: 1rpx solid rgba(100, 200, 255, 0.3);
  border-radius: 16rpx;
  display: block;
}

/* 云图信息框 */
.cloud-info-box {
  position: absolute;
  bottom: 160rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(10, 10, 15, 0.95);
  border: 2rpx solid rgba(100, 200, 255, 0.5);
  border-radius: 12rpx;
  padding: 20rpx;
  min-width: 280rpx;
  backdrop-filter: blur(20px);
  box-shadow: 0 8px 32px rgba(100, 200, 255, 0.2);
  animation: info-fade-in 0.3s ease-out;
  z-index: 60;
}

@keyframes info-fade-in {
  from {
    opacity: 0;
    transform: translateX(-50%) translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
}

.cloud-info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.cloud-info-title {
  font-size: 28rpx;
  color: #ffd700;
  font-weight: 700;
}

.cloud-info-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 20rpx;
  color: #c9a96e;
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.cloud-info-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
}

.cloud-legend {
  display: flex;
  gap: 40rpx;
  justify-content: center;
  margin-top: 24rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  box-shadow: 0 0 8rpx currentColor;
}

.legend-item text {
  font-size: 24rpx;
  color: #c9a96e;
}

/* === 徽章系统 === */
.badges-container {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.badge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx;
  background: rgba(255, 215, 0, 0.08);
  border: 1rpx solid rgba(255, 215, 0, 0.4);
  border-radius: 20rpx;
  transition: all 0.3s ease;
  backdrop-filter: blur(10px);
}

.badge-item:active {
  transform: scale(0.95);
  background: rgba(255, 215, 0, 0.15);
}

.badge-icon {
  font-size: 64rpx;
  animation: icon-float 2s ease-in-out infinite;
}

.badge-name {
  font-size: 22rpx;
  color: #e8d5a8;
  font-weight: 600;
}

@keyframes icon-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

/* === 数字人 === */
.ai-content {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 250rpx;
}

.ai-notice {
  font-size: 32rpx;
  color: #64c8ff;
  text-shadow: 0 0 20rpx rgba(100, 200, 255, 0.3);
}

/* 粒子效果 */
.particles-section {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  z-index: 0;
}

@keyframes float-up {
  0% {
    transform: translateY(0) translateX(0);
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  90% {
    opacity: 1;
  }
  100% {
    transform: translateY(-100vh) translateX(50px);
    opacity: 0;
  }
}

@keyframes float-up-reverse {
  0% {
    transform: translateY(0) translateX(0);
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  90% {
    opacity: 1;
  }
  100% {
    transform: translateY(-100vh) translateX(-50px);
    opacity: 0;
  }
}

.particle-dot {
  position: absolute;
  width: 4rpx;
  height: 4rpx;
  background: rgba(100, 200, 255, 0.6);
  border-radius: 50%;
  box-shadow: 0 0 8rpx rgba(100, 200, 255, 0.4);
}

.particle-dot:nth-child(odd) {
  animation: float-up 12s linear infinite;
  width: 2rpx;
  height: 2rpx;
  left: calc(15% + 20rpx * var(--i));
  background: rgba(201, 169, 110, 0.5);
}

.particle-dot:nth-child(even) {
  animation: float-up-reverse 14s linear infinite;
  width: 3rpx;
  height: 3rpx;
  right: calc(15% + 30rpx * var(--i));
  background: rgba(255, 105, 180, 0.4);
}

