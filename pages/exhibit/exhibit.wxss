.exhibit-container {
  width: 100%;
  height: 100vh;
  background: #0a0a0f;
  position: relative;
  overflow: hidden;
}

/* 顶部返回栏 */
.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 80rpx;
  background: rgba(10, 10, 15, 0.95);
  border-bottom: 2rpx solid rgba(100, 200, 255, 0.3);
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  z-index: 100;
  backdrop-filter: blur(20px);
  box-shadow: 0 0 30rpx rgba(100, 200, 255, 0.15);
}

.btn-back {
  color: #64c8ff;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.btn-back:active {
  opacity: 0.7;
  transform: scale(0.95);
}

/* 滚动容器 */
.sections-scroll {
  position: relative;
  width: 100%;
  height: 100%;
  padding-top: 80rpx;
  scroll-behavior: smooth;
}

/* 部分基础样式 */
.section {
  position: relative;
  width: 100%;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* === 背景图片 === */
.section-bg-image {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
}

/* === 卷轴叠加层 === */
.scroll-overlay {
  position: absolute;
  bottom: 130rpx;
  left: 50%;
  width: 200rpx;
  height: 200rpx;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  animation: scroll-entrance 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  pointer-events: auto;
  transform: translateX(-50%);
  border-radius: 50%;
  transition: all 0.3s ease;
}

.scroll-overlay:active {
  transform: translateX(-50%) scale(1.1);
  filter: brightness(1.2);
}

.scroll-glow-aura {
  position: absolute;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 215, 0, 0.6), transparent);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  filter: blur(20rpx);
  animation: scroll-glow-pulse 2s ease-in-out infinite;
}

@keyframes scroll-entrance {
  0% {
    opacity: 0;
    transform: scale(0.3) translateY(100px);
  }
  50% {
    opacity: 0.8;
  }
  100% {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

@keyframes scroll-glow-pulse {
  0%, 100% {
    opacity: 0.5;
    transform: translate(-50%, -50%) scale(1);
  }
  50% {
    opacity: 0.8;
    transform: translate(-50%, -50%) scale(1.1);
  }
}

.scroll-label {
  position: relative;
  z-index: 5;
  font-size: 28rpx;
  color: #ffd700;
  font-weight: 700;
  letter-spacing: 1rpx;
  text-shadow: 0 2px 8px rgba(255, 215, 0, 0.6), 0 0 20px rgba(255, 215, 0, 0.3);
  line-height: 1.5;
  text-align: center;
  animation: label-pulse 2s ease-in-out infinite;
}

.scroll-label-sub {
  position: relative;
  z-index: 5;
  font-size: 20rpx;
  color: rgba(255, 215, 0, 0.8);
  font-weight: 500;
  letter-spacing: 1rpx;
  text-shadow: 0 1px 4px rgba(255, 215, 0, 0.4);
  text-align: center;
  margin-top: 8rpx;
  animation: label-pulse 2s ease-in-out infinite;
  animation-delay: 0.2s;
}

@keyframes label-pulse {
  0%, 100% {
    opacity: 0.8;
  }
  50% {
    opacity: 1;
  }
}

/* === 各卷轴特定的门入动画 === */
.scroll-overlay-1 {
  /* 序章 - 卷轴在女性左手，position偏左下 */
  bottom: 100rpx !important;
  left: 30% !important;
  animation-delay: 0s;
}

.scroll-overlay-2 {
  /* 生平履历 - 卷轴在女性手中，position偏中央下 */
  bottom: 120rpx !important;
  left: 50% !important;
  animation-delay: 0.2s;
}

.scroll-overlay-3 {
  /* 治学风骨 - 卷轴在女性手中，position偏中央下 */
  bottom: 120rpx !important;
  left: 50% !important;
  animation-delay: 0.2s;
}

.scroll-overlay-4 {
  /* 科研丰碑 - 卷轴在女性手中，position位置偏中央 */
  bottom: 110rpx !important;
  left: 48% !important;
  animation-delay: 0.3s;
}

.scroll-overlay-5 {
  /* 尾声 - 卷轴在女性手中，position偏中央 */
  bottom: 130rpx !important;
  left: 48% !important;
  animation-delay: 0.4s;
}

/* 鼠标悬停效果 */
.scroll-overlay:active {
  animation: scroll-tap 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes scroll-tap {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(0.9);
  }
  100% {
    transform: scale(1);
  }
}

/* 卷轴展开出场动画 */
@keyframes scroll-expand-out {
  0% {
    opacity: 1;
    transform: scale(1);
  }
  100% {
    opacity: 0;
    transform: scale(2.5);
  }
}

/* === 内容区域 === */
.section-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.9;
  z-index: 0;
}

/* 背景梯度样式 - 仅用于第一部分（首页） */
.section-bg-1 {
  background: linear-gradient(135deg, rgba(10, 10, 15, 1) 0%, rgba(15, 15, 25, 0.8) 100%);
}

/* === 星空场景 === */
.stars-container {
  position: absolute;
  width: 100%;
  height: 100%;
}

.star {
  position: absolute;
  width: 2rpx;
  height: 2rpx;
  background: #fff;
  border-radius: 50%;
  opacity: 0.6;
  box-shadow: 0 0 4rpx rgba(255, 255, 255, 0.8);
  animation: twinkle 3s ease-in-out infinite;
}

@keyframes twinkle {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

/* 装饰框 */
.scene-frame {
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  border: 1rpx solid rgba(100, 200, 255, 0.1);
  opacity: 0.5;
}

/* === 书架场景 === */
.book-shelf-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  background: repeating-linear-gradient(
    90deg,
    transparent,
    transparent 80rpx,
    rgba(100, 200, 255, 0.05) 80rpx,
    rgba(100, 200, 255, 0.05) 160rpx
  );
}

.scene-decoration {
  position: absolute;
  width: 100%;
  height: 100%;
  z-index: 5;
  pointer-events: none;
}

/* 装饰圆形 */
.decoration-circle-1 {
  position: absolute;
  width: 300rpx;
  height: 300rpx;
  border: 1rpx solid rgba(100, 200, 255, 0.2);
  border-radius: 50%;
  left: 5%;
  top: 10%;
  animation: rotate-slow 20s linear infinite;
}

.decoration-circle-2 {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border: 1rpx solid rgba(201, 169, 110, 0.2);
  border-radius: 50%;
  right: 8%;
  bottom: 15%;
  animation: rotate-counter 25s linear infinite;
}

@keyframes rotate-slow {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes rotate-counter {
  from { transform: rotate(360deg); }
  to { transform: rotate(0deg); }
}

.decoration-line {
  position: absolute;
  width: 60%;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(100, 200, 255, 0.3), transparent);
  left: 20%;
  top: 50%;
  animation: pulse-line 2s ease-in-out infinite;
}

@keyframes pulse-line {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 0.8; }
}

/* === 书籍装饰 === */
.scene-books {
  display: flex;
  gap: 40rpx;
  align-items: flex-end;
  justify-content: center;
  opacity: 0.4;
}

.book {
  width: 60rpx;
  height: 200rpx;
  border: 2rpx solid rgba(201, 169, 110, 0.5);
  background: linear-gradient(90deg, rgba(139, 109, 20, 0.4), rgba(201, 169, 110, 0.2));
  border-radius: 4rpx;
}

.book-1 {
  height: 150rpx;
  animation: float-book 3s ease-in-out infinite;
}

.book-2 {
  height: 200rpx;
  animation: float-book 3.5s ease-in-out infinite 0.5s;
}

.book-3 {
  height: 170rpx;
  animation: float-book 3.2s ease-in-out infinite 0.2s;
}

@keyframes float-book {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-30rpx); }
}

/* === 研究/笔画装饰 === */
.scene-study .brush-strokes {
  position: absolute;
  width: 400rpx;
  height: 300rpx;
  right: 10%;
  top: 15%;
  background: repeating-linear-gradient(
    45deg,
    rgba(201, 169, 110, 0.1),
    rgba(201, 169, 110, 0.1) 10rpx,
    transparent 10rpx,
    transparent 20rpx
  );
  border: 1rpx solid rgba(201, 169, 110, 0.2);
  animation: paint-flow 4s ease-in-out infinite;
}

@keyframes paint-flow {
  0%, 100% { opacity: 0.2; transform: rotate(0deg); }
  50% { opacity: 0.5; transform: rotate(2deg); }
}

.scene-study .ink-splash {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  left: 10%;
  bottom: 20%;
  background: radial-gradient(circle, rgba(100, 200, 255, 0.1), transparent 70%);
  border-radius: 50%;
  filter: blur(20rpx);
  animation: ink-spread 3s ease-out infinite;
}

@keyframes ink-spread {
  0% { transform: scale(0.5); opacity: 0.5; }
  100% { transform: scale(1.5); opacity: 0; }
}

/* === 实验室场景 === */
.lab-scene {
  position: absolute;
  width: 100%;
  height: 100%;
  background: repeating-linear-gradient(
    0deg,
    rgba(100, 200, 255, 0.02),
    rgba(100, 200, 255, 0.02) 50rpx,
    transparent 50rpx,
    transparent 100rpx
  );
}

/* 电子轨道 */
.electron-orbits {
  position: absolute;
  width: 400rpx;
  height: 400rpx;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  z-index: 1;
}

.orbit {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  border: 1rpx solid rgba(100, 200, 255, 0.3);
  border-radius: 50%;
}

.orbit-1 {
  width: 150rpx;
  height: 150rpx;
  animation: orbit-rotate 8s linear infinite;
}

.orbit-2 {
  width: 250rpx;
  height: 250rpx;
  animation: orbit-rotate 12s linear infinite reverse;
}

.orbit-3 {
  width: 350rpx;
  height: 350rpx;
  animation: orbit-rotate 16s linear infinite;
}

@keyframes orbit-rotate {
  from { transform: translate(-50%, -50%) rotate(0deg); }
  to { transform: translate(-50%, -50%) rotate(360deg); }
}

.nucleus {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  background: radial-gradient(circle, rgba(100, 200, 255, 0.8), rgba(100, 200, 255, 0.3));
  border-radius: 50%;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 0 0 20rpx rgba(100, 200, 255, 0.6), inset 0 0 20rpx rgba(100, 200, 255, 0.4);
}

/* 测试管 */
.scene-lab {
  display: flex;
  gap: 120rpx;
  align-items: flex-end;
  justify-content: center;
}

.test-tube {
  width: 40rpx;
  height: 180rpx;
  border: 2rpx solid rgba(100, 200, 255, 0.4);
  border-radius: 0 0 20rpx 20rpx;
  background: linear-gradient(to bottom, transparent, rgba(100, 200, 255, 0.1));
  position: relative;
  animation: liquid-pulse 2s ease-in-out infinite;
}

.test-tube::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40%;
  background: linear-gradient(to bottom, rgba(100, 200, 255, 0.2), rgba(100, 200, 255, 0.4));
  border-radius: 0 0 18rpx 18rpx;
  animation: liquid-level 2s ease-in-out infinite;
}

@keyframes liquid-pulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

@keyframes liquid-level {
  0%, 100% { height: 40%; }
  50% { height: 60%; }
}

.test-tube-1 {
  animation-delay: 0s;
}

.test-tube-2 {
  animation-delay: 0.3s;
}

.equipment {
  position: absolute;
  right: 10%;
  bottom: 20%;
  width: 200rpx;
  height: 100rpx;
  border: 1rpx solid rgba(100, 200, 255, 0.3);
  border-radius: 8rpx;
  background: linear-gradient(135deg, rgba(100, 200, 255, 0.05), transparent);
  opacity: 0.5;
}

