      ],
      "difficultyLevel": "basic",
      "digitalHumanPrompt": true
    },
    {
      "id": "node_1912_birth_04",
      "nodeBinding": "node_1912_birth",
      "theme": "生平履历",
      "contentType": "节点描述",
      "text": "吴健雄的母亲樊复华是一位贤惠温柔、慈祥宽厚的家庭主妇，是一位非常明白事理的人。她总是把孩子们的前程放在第一位。吴健雄是惟一的女儿，她在处理儿女们的关系上，感情的天平总是向女儿倾斜的。从小健雄开始懂事的那一天起，樊复华就开始给孩子灌输各种知识，教她认方块字、讲故事等。妈妈认真教学，女儿聪明好学。所以她常跟人说，母爱是纯真的，洁白得没有半点纤尘。",
      "spiritKeywords": [
        "启程之光",
        "求知种子"
      ],
      "sourceChapter": "第一章",
      "sourceLines": "L887-L897",
      "length": 172,
      "keywords": [
        "母亲",
        "樊复华",
        "家庭教育",
        "启蒙"
      ],
      "containsQuote": false,
      "quoteText": "",
      "suitableFor": [
        "讲解态",
        "问答态"
      ],
      "difficultyLevel": "basic",
      "digitalHumanPrompt": true
    },
